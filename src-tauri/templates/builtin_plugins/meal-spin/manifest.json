{
  "id": "meal-spin",
  "name": "今天吃喝什么",
  "version": "0.6.2",
  "description": "吃/喝转盘。指针与结果对齐；mode 等可用闹钟环境变量覆盖。",
  "permissions": [
    "storage",
    "timer",
    "notification"
  ],
  "ui": "ui.html",
  "params": {
    "mode": {
      "description": "food 或 drink",
      "default": "food",
      "enum": [
        "food",
        "drink"
      ]
    },
    "spinSeconds": {
      "description": "转动秒数",
      "default": 4
    },
    "autoNotify": {
      "description": "转完后通知",
      "default": true
    },
    "lockMode": {
      "description": "锁定 mode 切换",
      "default": false
    }
  }
}

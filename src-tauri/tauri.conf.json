{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "callai",
  "version": "0.2.5",
  "identifier": "com.yunxuan.callai",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "callai",
        "width": 420,
        "height": 740,
        "minWidth": 386,
        "minHeight": 217,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGMjIyQUE4RTBGNkY0NzMKUldSejlQYmdxQ29pN3p1djBJdTdYcythUnZhd0t3QWxjbHRXL3dtemRRYjltSUhQMTBjWjFsZzIK",
      "endpoints": [
        "https://github.com/YuniqueUnic/callai/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

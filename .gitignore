assets/brand/callai.iconset/

# Force-track app icons (global ~/.gitignore has Icon? which matches *icon*)

# NOTE: macOS personal global gitignore often contains `Icon?` which matches
# paths containing "icon" (e.g. src-tauri/icons/*). If icons disappear from
# `git status`, re-add with: git add -f src-tauri/icons public/icons
!src-tauri/icons/
!src-tauri/icons/**
!public/icons/
!public/icons/**
!docs/assets/
!docs/assets/**

# Signing keys (never commit private keys)
.keys/
*.key
!*.key.pub

# Local screenshot tooling / huge originals (keep optimized docs assets)
assets/screenshot/.venv/
assets/screenshot/original/
**/assets/screenshot/original/**

